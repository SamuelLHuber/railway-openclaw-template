{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "namespace": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "labels": { "type": "object" }
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "gatewayPassword": { "type": "string" },
        "allowedOrigin": { "type": "string" },
        "providerKeys": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "accessMode": { "type": "string", "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"] },
        "size": { "type": "string", "minLength": 1 },
        "storageClassName": { "type": "string" }
      }
    },
    "openclaw": {
      "type": "object",
      "properties": {
        "bootstrap": {
          "type": "object",
          "properties": {
            "modelPrimary": { "type": "string", "minLength": 1 }
          }
        },
        "gateway": {
          "type": "object",
          "properties": {
            "trustedProxies": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "httpRoute": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hostname": { "type": "string" },
        "parentRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "namespace"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "namespace": { "type": "string", "minLength": 1 },
              "group": { "type": "string" },
              "kind": { "type": "string" },
              "sectionName": { "type": "string" }
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressFrom": {
          "type": "array",
          "items": { "type": "object" }
        },
        "dnsTo": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object" }
        },
        "publicInternetExceptCidrs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "secret": {
            "properties": { "create": { "const": true } },
            "required": ["create"]
          }
        }
      },
      "then": {
        "properties": {
          "secret": {
            "required": ["gatewayPassword", "allowedOrigin"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "secret": {
            "properties": {
              "create": { "const": false },
              "existingSecret": { "maxLength": 0 }
            },
            "required": ["create", "existingSecret"]
          }
        }
      },
      "then": false
    },
    {
      "if": {
        "properties": {
          "httpRoute": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "httpRoute": {
            "required": ["hostname", "parentRefs"],
            "properties": {
              "hostname": { "minLength": 1 },
              "parentRefs": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "networkPolicy": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "networkPolicy": {
            "required": ["ingressFrom", "dnsTo", "publicInternetExceptCidrs"],
            "properties": {
              "ingressFrom": { "minItems": 1 }
            }
          }
        }
      }
    }
  ]
}
