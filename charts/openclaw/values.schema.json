{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "namespace": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "labels": { "type": "object" }
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "gatewayPassword": { "type": "string" },
        "allowedOrigin": { "type": "string" },
        "providerKeys": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "accessMode": { "type": "string", "enum": ["ReadWriteOnce", "ReadWriteMany", "ReadOnlyMany"] },
        "size": { "type": "string", "minLength": 1 },
        "storageClassName": { "type": "string" }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "openclaw": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "limits": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "initContainer": {
          "type": "object",
          "properties": {
            "requests": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "limits": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      }
    },
    "openclaw": {
      "type": "object",
      "properties": {
        "bootstrap": {
          "type": "object",
          "properties": {
            "modelPrimary": { "type": "string", "minLength": 1 }
          }
        },
        "gateway": {
          "type": "object",
          "properties": {
            "trustedProxies": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "runtimeAsRoot": { "type": "boolean" },
        "runtimePackageManagerCompat": { "type": "boolean" }
      }
    },
    "httpRoute": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hostname": { "type": "string" },
        "parentRefs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "namespace"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "namespace": { "type": "string", "minLength": 1 },
              "group": { "type": "string" },
              "kind": { "type": "string" },
              "sectionName": { "type": "string" }
            }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "denyEgress": { "type": "boolean" },
        "allowMailEgress": { "type": "boolean" },
        "mailPorts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 }
        },
        "ingressFrom": {
          "type": "array",
          "items": { "type": "object" }
        },
        "dnsTo": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object" }
        },
        "publicInternetExceptCidrs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "backup": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "schedule": { "type": "string", "minLength": 1 },
        "successfulJobsHistoryLimit": { "type": "integer", "minimum": 0 },
        "failedJobsHistoryLimit": { "type": "integer", "minimum": 0 },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "archive": {
          "type": "object",
          "properties": {
            "includeWorkspace": { "type": "boolean" },
            "onlyConfig": { "type": "boolean" }
          }
        },
        "resources": {
          "type": "object",
          "properties": {
            "createBackup": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            },
            "restic": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          }
        },
        "restic": {
          "type": "object",
          "properties": {
            "createSecret": { "type": "boolean" },
            "existingSecret": { "type": "string" },
            "repository": { "type": "string" },
            "password": { "type": "string" },
            "extraEnv": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "retention": {
          "type": "object",
          "properties": {
            "keepHourly": { "type": "integer", "minimum": 1 },
            "keepDaily": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "restore": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "runId": { "type": "string" },
        "snapshot": { "type": "string", "minLength": 1 },
        "existingSecret": { "type": "string" },
        "preserveCurrentState": { "type": "boolean" },
        "resources": {
          "type": "object",
          "properties": {
            "resticRestore": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            },
            "verifyBackup": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            },
            "applyRestore": {
              "type": "object",
              "properties": {
                "requests": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "limits": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "secret": {
            "properties": { "create": { "const": true } },
            "required": ["create"]
          }
        }
      },
      "then": {
        "properties": {
          "secret": {
            "required": ["gatewayPassword", "allowedOrigin"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "secret": {
            "properties": {
              "create": { "const": false },
              "existingSecret": { "maxLength": 0 }
            },
            "required": ["create", "existingSecret"]
          }
        }
      },
      "then": false
    },
    {
      "if": {
        "properties": {
          "httpRoute": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "httpRoute": {
            "required": ["hostname", "parentRefs"],
            "properties": {
              "hostname": { "minLength": 1 },
              "parentRefs": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "networkPolicy": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "networkPolicy": {
            "required": ["ingressFrom"],
            "properties": {
              "ingressFrom": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "networkPolicy": {
            "properties": {
              "enabled": { "const": true },
              "denyEgress": { "const": true }
            },
            "required": ["enabled", "denyEgress"]
          }
        }
      },
      "then": {
        "properties": {
          "networkPolicy": {
            "required": ["dnsTo", "publicInternetExceptCidrs"],
            "properties": {
              "dnsTo": { "minItems": 1 },
              "publicInternetExceptCidrs": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "networkPolicy": {
            "properties": {
              "enabled": { "const": true },
              "denyEgress": { "const": true },
              "allowMailEgress": { "const": true }
            },
            "required": ["enabled", "denyEgress", "allowMailEgress"]
          }
        }
      },
      "then": {
        "properties": {
          "networkPolicy": {
            "required": ["mailPorts"],
            "properties": {
              "mailPorts": { "minItems": 1 }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "backup": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "backup": {
            "required": ["schedule", "restic", "retention"],
            "properties": {
              "retention": {
                "required": ["keepHourly", "keepDaily"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "backup": {
            "properties": {
              "enabled": { "const": true },
              "restic": {
                "properties": { "createSecret": { "const": true } },
                "required": ["createSecret"]
              }
            },
            "required": ["enabled", "restic"]
          }
        }
      },
      "then": {
        "properties": {
          "backup": {
            "properties": {
              "restic": {
                "required": ["repository", "password"],
                "properties": {
                  "repository": { "minLength": 1 },
                  "password": { "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "backup": {
            "properties": {
              "enabled": { "const": true },
              "restic": {
                "properties": { "createSecret": { "const": false } },
                "required": ["createSecret"]
              }
            },
            "required": ["enabled", "restic"]
          }
        }
      },
      "then": {
        "properties": {
          "backup": {
            "properties": {
              "restic": {
                "required": ["existingSecret"],
                "properties": {
                  "existingSecret": { "minLength": 1 }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "restore": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        }
      },
      "then": {
        "properties": {
          "restore": {
            "required": ["runId", "snapshot"],
            "properties": {
              "runId": { "minLength": 1 },
              "snapshot": { "minLength": 1 }
            }
          }
        }
      }
    }
  ]
}
