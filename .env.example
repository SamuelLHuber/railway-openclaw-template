# OpenClaw .env for Railway
# Copy relevant vars to your Railway service's environment variables.
# Only set the providers/channels you actually use.

# ─── Required ────────────────────────────────────────────────────
# Gateway auth token (secures the API).
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token

# Port the gateway listens on. Railway auto-detects this.
PORT=8080

# ─── Pin a specific release (optional) ──────────────────────────
# Set as a Railway build arg to pin the image version.
# Omit or set to "latest" to track the newest stable release.
# OPENCLAW_VERSION=2026.3.1

# ─── Model provider API keys (set at least one) ─────────────────
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...

# ─── Channels (optional) ────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABCDEF...
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ─── Tools (optional) ───────────────────────────────────────────
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...
